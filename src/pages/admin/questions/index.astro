---
import Layout from '../../../layouts/Layout.astro';
import { getAllQuestions } from '../../../lib/supabase';



const questions = await getAllQuestions();
---

<Layout>
  <main class="min-h-screen bg-gray-50 px-4 py-12">
    <div class="mx-auto max-w-4xl">

      <!-- Header -->
      <div class="mb-8">
        <p class="text-sm font-medium text-indigo-600">Admin</p>
        <h1 class="mt-1 text-2xl font-bold text-gray-900">Question Management</h1>
        <p class="mt-1 text-sm text-gray-500">
          Only one question can be active at a time. The active question is shown on the survey page.
        </p>
      </div>

      <!-- Toast notification -->
      <div
        id="toast"
        hidden
        role="status"
        aria-live="polite"
        class="mb-6 rounded-lg px-4 py-3 text-sm font-medium"
      ></div>

      {questions.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-12 text-center">
          <p class="text-gray-400">No questions found.</p>
        </div>
      ) : (
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
          <ul class="divide-y divide-gray-100" id="question-list">
            {questions.map((q) => (
              <li
                id={`question-${q.id}`}
                data-active={String(q.is_active)}
                class:list={[
                  'flex items-start justify-between gap-4 px-6 py-4 transition-colors',
                  q.is_active ? 'bg-indigo-50' : 'hover:bg-gray-50',
                ]}
              >
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2.5 flex-wrap">
                    <!-- Type badge -->
                    <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 capitalize">
                      {q.type.replace('_', ' ')}
                    </span>
                    <!-- Active badge -->
                    {q.is_active && (
                      <span class="active-badge inline-flex items-center gap-1 rounded-md bg-indigo-100 px-2 py-0.5 text-xs font-semibold text-indigo-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-indigo-500" aria-hidden="true"></span>
                        Active
                      </span>
                    )}
                  </div>
                  <p class="mt-1.5 text-sm text-gray-900">{q.prompt}</p>
                </div>

                <div class="flex shrink-0 items-center gap-2">
                  {q.is_active ? (
                    <button
                      data-id={q.id}
                      data-action="deactivate"
                      class="action-btn rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-600 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                      Deactivate
                    </button>
                  ) : (
                    <button
                      data-id={q.id}
                      data-action="activate"
                      class="action-btn rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                      Set Active
                    </button>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Links -->
      <div class="mt-6 flex gap-4 text-sm">
        <a href="/" class="text-indigo-600 hover:underline">← Survey page</a>
        <a href="/admin/responses" class="text-indigo-600 hover:underline">View responses →</a>
      </div>

    </div>
  </main>
</Layout>

<script>
  const toast = document.getElementById('toast') as HTMLDivElement;

  function showToast(message: string, type: 'success' | 'error'): void {
    toast.textContent = message;
    toast.className = [
      'mb-6 rounded-lg px-4 py-3 text-sm font-medium',
      type === 'success'
        ? 'bg-green-50 text-green-700 border border-green-200'
        : 'bg-red-50 text-red-700 border border-red-200',
    ].join(' ');
    toast.hidden = false;
    setTimeout(() => { toast.hidden = true; }, 3000);
  }

  function setRowActive(id: number, active: boolean): void {
    const all = document.querySelectorAll<HTMLLIElement>('#question-list li');

    for (const li of all) {
      const liId = Number(li.id.replace('question-', ''));
      const isThis = liId === id;
      const shouldBeActive = isThis && active;

      // Background
      li.classList.toggle('bg-indigo-50', shouldBeActive);
      li.classList.toggle('hover:bg-gray-50', !shouldBeActive);

      // Active badge
      const existingBadge = li.querySelector('.active-badge');
      if (shouldBeActive && !existingBadge) {
        const badge = document.createElement('span');
        badge.className = 'active-badge inline-flex items-center gap-1 rounded-md bg-indigo-100 px-2 py-0.5 text-xs font-semibold text-indigo-700';
        badge.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-indigo-500" aria-hidden="true"></span> Active';
        li.querySelector('.flex.items-center.gap-2\\.5')?.appendChild(badge);
      } else if (!shouldBeActive && existingBadge) {
        existingBadge.remove();
      }

      // Button
      const btn = li.querySelector<HTMLButtonElement>('.action-btn');
      if (!btn) continue;

      if (shouldBeActive) {
        btn.dataset.action = 'deactivate';
        btn.textContent = 'Deactivate';
        btn.className = 'action-btn rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-600 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50';
      } else {
        btn.dataset.action = 'activate';
        btn.textContent = 'Set Active';
        btn.className = 'action-btn rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50';
      }
    }
  }

  document.getElementById('question-list')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.action-btn');
    if (!btn) return;

    const id = Number(btn.dataset.id);
    const action = btn.dataset.action as 'activate' | 'deactivate';
    const active = action === 'activate';

    // Disable all buttons during request
    const allBtns = document.querySelectorAll<HTMLButtonElement>('.action-btn');
    allBtns.forEach((b) => { b.disabled = true; });
    btn.textContent = active ? 'Activating…' : 'Deactivating…';

    try {
      const res = await fetch('/api/questions/activate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, active }),
      });

      const data = await res.json();

      if (!res.ok) {
        showToast(data.error ?? 'Something went wrong.', 'error');
        // Re-enable buttons without changing state
        allBtns.forEach((b) => { b.disabled = false; });
        btn.textContent = active ? 'Set Active' : 'Deactivate';
        return;
      }

      setRowActive(id, active);
      showToast(
        active ? 'Question is now active.' : 'Question deactivated.',
        'success'
      );
    } catch {
      showToast('Network error. Please try again.', 'error');
      allBtns.forEach((b) => { b.disabled = false; });
      btn.textContent = active ? 'Set Active' : 'Deactivate';
    } finally {
      // Re-enable all buttons (setRowActive already set correct labels for success case)
      document.querySelectorAll<HTMLButtonElement>('.action-btn').forEach((b) => {
        b.disabled = false;
      });
    }
  });
</script>
