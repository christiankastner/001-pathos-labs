---
import Layout from '../../layouts/Layout.astro';
import { getActiveQuestion } from '../../lib/supabase';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL as string;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_KEY as string;

const question = await getActiveQuestion();
---

<Layout>
  <main class="min-h-screen bg-gray-50 px-4 py-12">
    <div class="mx-auto max-w-2xl">

      <!-- Header -->
      <div class="mb-8">
        <p class="text-sm font-medium text-indigo-600">Admin</p>
        <h1 class="mt-1 text-2xl font-bold text-gray-900">Response Simulator</h1>
        <p class="mt-1 text-sm text-gray-500">
          Simulates 100 people submitting the active question over a 5-minute window.
        </p>
      </div>

      {question ? (
        <>
          <!-- Active question card -->
          <div class="mb-6 rounded-2xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
            <div class="flex items-center gap-2.5 mb-2">
              <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 capitalize">
                {question.type.replace('_', ' ')}
              </span>
              <span class="inline-flex items-center gap-1 rounded-md bg-indigo-100 px-2 py-0.5 text-xs font-semibold text-indigo-700">
                <span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
                Active
              </span>
            </div>
            <p class="text-sm font-medium text-gray-900">{question.prompt}</p>
            {question.options.length > 0 && (
              <ul class="mt-3 space-y-1">
                {question.options.map((o) => (
                  <li class="text-xs text-gray-500">· {o.label} <span class="text-gray-400">({o.value})</span></li>
                ))}
              </ul>
            )}
          </div>

          <!-- Controls -->
          <div class="mb-6 flex items-center gap-3 flex-wrap">
            <button
              id="start-btn"
              class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50"
            >
              Start
            </button>
            <button
              id="stop-btn"
              hidden
              class="rounded-lg border border-gray-300 bg-white px-5 py-2 text-sm font-medium text-gray-600 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1"
            >
              Stop
            </button>
            <button
              id="clear-btn"
              class="rounded-lg border border-red-200 bg-white px-5 py-2 text-sm font-medium text-red-600 shadow-sm hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50"
            >
              Clear answers
            </button>
            <span id="status-text" class="text-sm text-gray-500"></span>
          </div>

          <!-- Progress bar -->
          <div id="progress-section" hidden class="mb-6">
            <div class="mb-1.5 flex items-center justify-between text-xs text-gray-500">
              <span id="progress-label">0 / 100 submitted</span>
              <span id="time-label"></span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-gray-200">
              <div id="progress-bar" class="h-full rounded-full bg-indigo-500 transition-all duration-300" style="width: 0%"></div>
            </div>
          </div>

          <!-- Log -->
          <div id="log-section" hidden class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
            <div class="border-b border-gray-100 px-5 py-3">
              <h2 class="text-sm font-semibold text-gray-700">Submission log</h2>
            </div>
            <ul id="log-list" class="divide-y divide-gray-50 max-h-80 overflow-y-auto text-xs font-mono"></ul>
          </div>
        </>
      ) : (
        <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-12 text-center text-sm text-gray-400">
          No question is currently active. Activate one from the
          <a href="/admin/questions" class="text-indigo-600 hover:underline ml-1">questions page</a>.
        </div>
      )}

      <!-- Links -->
      <div class="mt-6 flex gap-4 text-sm">
        <a href="/admin/questions" class="text-indigo-600 hover:underline">← Questions</a>
        <a href="/admin/responses" class="text-indigo-600 hover:underline">View responses →</a>
      </div>

    </div>
  </main>
</Layout>

{question && (
  <script
    data-supabase-url={supabaseUrl}
    data-supabase-key={supabaseKey}
    data-question={JSON.stringify({
      id: question.id,
      type: question.type,
      options: question.options.map((o) => o.value),
    })}
    is:inline
  >
    // ── Bootstrap ────────────────────────────────────────────────────────────
    const script    = document.currentScript;
    const sbUrl     = script.dataset.supabaseUrl;
    const sbKey     = script.dataset.supabaseKey;
    const question  = JSON.parse(script.dataset.question);

    const TOTAL        = 100;
    const WINDOW_MS    = 5 * 60 * 1000; // 5 minutes

    // ── Supabase minimal client (no SDK needed — plain fetch) ────────────────
    async function upsertRow(table, row) {
      const res = await fetch(`${sbUrl}/rest/v1/${table}`, {
        method: 'POST',
        headers: {
          'apikey': sbKey,
          'Authorization': `Bearer ${sbKey}`,
          'Content-Type': 'application/json',
          'Prefer': 'resolution=merge-duplicates',
        },
        body: JSON.stringify(row),
      });
      if (!res.ok) throw new Error(`${table} upsert failed: ${res.status}`);
    }

    // ── Random answer generator ───────────────────────────────────────────────
    const FREE_TEXT_POOL = [
      'I think this is very important.',
      'Not sure, needs more research.',
      'Strongly agree with this direction.',
      'This concerns me quite a bit.',
      'Great question — hard to say.',
      'Definitely yes, without a doubt.',
      'No opinion on this one.',
      'Very relevant to my experience.',
      'Could go either way honestly.',
      'This is something I care about.',
      'Needs more public discussion.',
      'Absolutely, 100%.',
      'I\'d like to see more data first.',
      'Mixed feelings about this.',
      'Yes, but only under strict conditions.',
      'No, I disagree strongly.',
      'More nuance needed here.',
      'Somewhat agree, somewhat don\'t.',
      'This matters a lot to me.',
      'Hard to know without more context.',
    ];

    function randomAnswer() {
      const { type, options } = question;
      if (type === 'multiple_choice' || type === 'dropdown') {
        return options[Math.floor(Math.random() * options.length)];
      }
      if (type === 'select_all') {
        // Random non-empty subset
        const shuffled = [...options].sort(() => Math.random() - 0.5);
        const count = 1 + Math.floor(Math.random() * shuffled.length);
        return shuffled.slice(0, count).join(',');
      }
      // free_text
      return FREE_TEXT_POOL[Math.floor(Math.random() * FREE_TEXT_POOL.length)];
    }

    // ── UI refs ───────────────────────────────────────────────────────────────
    const startBtn       = document.getElementById('start-btn');
    const stopBtn        = document.getElementById('stop-btn');
    const clearBtn       = document.getElementById('clear-btn');
    const statusText     = document.getElementById('status-text');
    const progressSection = document.getElementById('progress-section');
    const progressBar    = document.getElementById('progress-bar');
    const progressLabel  = document.getElementById('progress-label');
    const timeLabel      = document.getElementById('time-label');
    const logSection     = document.getElementById('log-section');
    const logList        = document.getElementById('log-list');

    // ── Simulation state ──────────────────────────────────────────────────────
    let timers   = [];
    let submitted = 0;
    let errors    = 0;
    let startTime = null;
    let tickInterval = null;

    function updateProgress() {
      const pct = (submitted / TOTAL) * 100;
      progressBar.style.width = `${pct}%`;
      progressLabel.textContent = `${submitted} / ${TOTAL} submitted${errors > 0 ? ` (${errors} failed)` : ''}`;
      if (startTime) {
        const elapsed = Math.floor((Date.now() - startTime) / 1000);
        const remaining = Math.max(0, Math.ceil((WINDOW_MS - (Date.now() - startTime)) / 1000));
        timeLabel.textContent = remaining > 0 ? `${remaining}s remaining` : 'window closed';
      }
    }

    function appendLog(sessionId, answer, ok) {
      const short = sessionId.slice(0, 8);
      const li = document.createElement('li');
      li.className = `px-5 py-2 flex items-center gap-3 ${ok ? '' : 'bg-red-50'}`;
      li.innerHTML = `
        <span class="${ok ? 'text-green-600' : 'text-red-500'}">${ok ? '✓' : '✗'}</span>
        <span class="text-gray-400">${short}…</span>
        <span class="text-gray-700 truncate">${answer}</span>
      `;
      logList.prepend(li);
      // Keep log capped at 200 entries
      while (logList.children.length > 200) logList.lastElementChild.remove();
    }

    async function submitOne() {
      const sessionId = crypto.randomUUID();
      const answer    = randomAnswer();
      let ok = false;
      try {
        await upsertRow('sessions', { id: sessionId });
        await upsertRow('answers', {
          session_id:  sessionId,
          question_id: question.id,
          value:       answer,
        });
        submitted++;
        ok = true;
      } catch {
        errors++;
      }
      appendLog(sessionId, answer, ok);
      updateProgress();
    }

    function stopSimulation(reason) {
      timers.forEach(clearTimeout);
      timers = [];
      clearInterval(tickInterval);
      startBtn.disabled = false;
      startBtn.hidden   = false;
      stopBtn.hidden    = true;
      statusText.textContent = reason ?? '';
    }

    function startSimulation() {
      submitted = 0;
      errors    = 0;
      startTime = Date.now();
      logList.innerHTML = '';

      startBtn.disabled = true;
      startBtn.hidden   = true;
      stopBtn.hidden    = false;
      progressSection.hidden = false;
      logSection.hidden      = false;
      statusText.textContent = 'Running…';

      updateProgress();

      // Generate 100 random offsets within the window and sort them
      const offsets = Array.from({ length: TOTAL }, () => Math.random() * WINDOW_MS);
      offsets.sort((a, b) => a - b);

      timers = offsets.map((offset) =>
        setTimeout(submitOne, offset)
      );

      // Tick every second to update the countdown
      tickInterval = setInterval(updateProgress, 1000);

      // Final cleanup after window closes
      timers.push(
        setTimeout(() => stopSimulation('Simulation complete.'), WINDOW_MS + 2000)
      );
    }

    startBtn.addEventListener('click', startSimulation);
    stopBtn.addEventListener('click', () => stopSimulation('Stopped.'));

    clearBtn.addEventListener('click', async () => {
      clearBtn.disabled = true;
      clearBtn.textContent = 'Clearing…';
      try {
        const res = await fetch('/api/answers/clear', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question_id: question.id }),
        });
        const data = await res.json();
        if (!res.ok) {
          statusText.textContent = data.error ?? 'Clear failed.';
        } else {
          statusText.textContent = `Cleared ${data.deleted} answer${data.deleted === 1 ? '' : 's'}.`;
          logList.innerHTML = '';
          progressSection.hidden = true;
          logSection.hidden = true;
        }
      } catch {
        statusText.textContent = 'Network error.';
      } finally {
        clearBtn.disabled = false;
        clearBtn.textContent = 'Clear answers';
      }
    });
  </script>
)}
