---
import type { QuestionWithOptions } from '../../lib/database.types';
import MultipleChoice from './MultipleChoice.astro';
import SelectAll from './SelectAll.astro';
import Dropdown from './Dropdown.astro';
import FreeText from './FreeText.astro';

interface Props {
  question: QuestionWithOptions;
  value?: string | string[];
  error?: string;
}

const { question, value, error } = Astro.props;

const inputName  = `question_${question.id}`;
const promptId   = `prompt-${question.id}`;

const scalarValue = Array.isArray(value) ? value[0] : value;
const arrayValue  = Array.isArray(value) ? value : value ? [value] : [];
---

<div
  class="border border-white/60 bg-gray-650/40 p-7 shadow-2xl backdrop-blur-2xl"
  data-question-id={question.id}
  data-question-type={question.type}
  data-question-required={question.required.toString()}
>
  <!-- Prompt -->
  <p id={promptId} class="mb-8 text-xl font-medium text-white">
    {question.prompt}
  </p>

  <!-- Input -->
  {question.type === 'multiple_choice' && (
    <MultipleChoice
      name={inputName}
      options={question.options}
      value={scalarValue}
      labelId={promptId}
      required={question.required}
    />
  )}
  {question.type === 'select_all' && (
    <SelectAll
      name={inputName}
      options={question.options}
      values={arrayValue}
      labelId={promptId}
      required={question.required}
    />
  )}
  {question.type === 'dropdown' && (
    <Dropdown
      name={inputName}
      options={question.options}
      value={scalarValue}
      labelId={promptId}
      required={question.required}
    />
  )}
  {question.type === 'free_text' && (
    <FreeText
      name={inputName}
      value={scalarValue}
      labelId={promptId}
      required={question.required}
    />
  )}

  <!-- Error slot (server-rendered; client also injects errors here) -->
  {error && (
    <p class="mt-3 text-sm text-rose-400" role="alert" data-error>{error}</p>
  )}
  <div class="mt-6 flex items-center justify-between">
    <button
      id="submit-btn"
      type="submit"
      class="ml-auto bg-violet-600 px-7 py-2.5 text-sm font-semibold text-white shadow-lg shadow-violet-900/40 transition-all hover:bg-violet-500 hover:shadow-violet-800/50 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 focus:ring-offset-transparent disabled:cursor-not-allowed disabled:opacity-40"
    >
      Submit
    </button>
  </div>
</div>
