---
import type { QuestionWithOptions } from '../../lib/database.types';
import MultipleChoice from './MultipleChoice.astro';
import SelectAll from './SelectAll.astro';
import Dropdown from './Dropdown.astro';
import FreeText from './FreeText.astro';

interface Props {
  question: QuestionWithOptions;
  bucketName?: string;
  value?: string | string[];
  error?: string;
}

const { question, bucketName, value, error } = Astro.props;

const inputName = `question_${question.id}`;
const promptId  = `prompt-${question.id}`;

const scalarValue = Array.isArray(value) ? value[0] : value;
const arrayValue  = Array.isArray(value) ? value : value ? [value] : [];

// ── Per-bucket colour themes ─────────────────────────────────────────────────
// All class strings must be written in full so Tailwind includes them in the build.
const THEMES: Record<string, {
  border: string;
  bg: string;
  button: string;
  accent: string;
  inputFocus: string;
}> = {
  'Environment': {
    border:     'border-emerald-400/50',
    bg:         'bg-emerald-950/40',
    button:     'bg-emerald-600 hover:bg-emerald-500 shadow-emerald-900/40 hover:shadow-emerald-800/50 focus:ring-emerald-500',
    accent:     'accent-emerald-500',
    inputFocus: 'focus:border-emerald-500/60 focus:ring-emerald-500/30',
  },
  'Health': {
    border:     'border-rose-400/50',
    bg:         'bg-rose-950/40',
    button:     'bg-rose-600 hover:bg-rose-500 shadow-rose-900/40 hover:shadow-rose-800/50 focus:ring-rose-500',
    accent:     'accent-rose-500',
    inputFocus: 'focus:border-rose-500/60 focus:ring-rose-500/30',
  },
  'Technology': {
    border:     'border-sky-400/50',
    bg:         'bg-sky-950/40',
    button:     'bg-sky-600 hover:bg-sky-500 shadow-sky-900/40 hover:shadow-sky-800/50 focus:ring-sky-500',
    accent:     'accent-sky-500',
    inputFocus: 'focus:border-sky-500/60 focus:ring-sky-500/30',
  },
  'Education': {
    border:     'border-amber-400/50',
    bg:         'bg-amber-950/40',
    button:     'bg-amber-600 hover:bg-amber-500 shadow-amber-900/40 hover:shadow-amber-800/50 focus:ring-amber-500',
    accent:     'accent-amber-500',
    inputFocus: 'focus:border-amber-500/60 focus:ring-amber-500/30',
  },
  'Society & Work': {
    border:     'border-violet-400/50',
    bg:         'bg-violet-950/40',
    button:     'bg-violet-600 hover:bg-violet-500 shadow-violet-900/40 hover:shadow-violet-800/50 focus:ring-violet-500',
    accent:     'accent-violet-500',
    inputFocus: 'focus:border-violet-500/60 focus:ring-violet-500/30',
  },
};

const DEFAULT_THEME = THEMES['Society & Work'];
const theme = (bucketName && THEMES[bucketName]) ? THEMES[bucketName] : DEFAULT_THEME;
---

<div
  class:list={[
    'border p-7 shadow-2xl backdrop-blur-2xl',
    theme.border,
    theme.bg,
  ]}
  data-question-id={question.id}
  data-question-type={question.type}
  data-question-required={question.required.toString()}
>
  <!-- Prompt -->
  <p id={promptId} class="mb-8 text-xl font-medium text-white">
    {question.prompt}
  </p>

  <!-- Input -->
  {question.type === 'multiple_choice' && (
    <MultipleChoice
      name={inputName}
      options={question.options}
      value={scalarValue}
      labelId={promptId}
      required={question.required}
      accentClass={theme.accent}
    />
  )}
  {question.type === 'select_all' && (
    <SelectAll
      name={inputName}
      options={question.options}
      values={arrayValue}
      labelId={promptId}
      required={question.required}
      accentClass={theme.accent}
    />
  )}
  {question.type === 'dropdown' && (
    <Dropdown
      name={inputName}
      options={question.options}
      value={scalarValue}
      labelId={promptId}
      required={question.required}
      inputFocusClass={theme.inputFocus}
    />
  )}
  {question.type === 'free_text' && (
    <FreeText
      name={inputName}
      value={scalarValue}
      labelId={promptId}
      required={question.required}
      inputFocusClass={theme.inputFocus}
    />
  )}

  <!-- Error slot -->
  {error && (
    <p class="mt-3 text-sm text-rose-400" role="alert" data-error>{error}</p>
  )}

  <div class="mt-8 flex items-center justify-between">
    <button
      id="submit-btn"
      type="submit"
      class:list={[
        'ml-auto px-7 py-2.5 text-sm font-semibold text-white shadow-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-transparent disabled:cursor-not-allowed disabled:opacity-40',
        theme.button,
      ]}
    >
      Submit
    </button>
  </div>
</div>
