---
import type { QuestionWithOptions } from '../../lib/database.types';
import MultipleChoice from './MultipleChoice.astro';
import SelectAll from './SelectAll.astro';
import Dropdown from './Dropdown.astro';
import FreeText from './FreeText.astro';

interface Props {
  question: QuestionWithOptions;
  value?: string | string[];
  error?: string;
}

const { question, value, error } = Astro.props;

const inputName = `question_${question.id}`;

// Normalise value for each type
const scalarValue = Array.isArray(value) ? value[0] : value;
const arrayValue  = Array.isArray(value) ? value : value ? [value] : [];
---

<div
  class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm"
  data-question-id={question.id}
  data-question-type={question.type}
  data-question-required={question.required.toString()}
>
  <!-- prompt + required indicator -->
  <p class="mb-4 text-base font-medium text-gray-900">
    {question.prompt}
    {question.required && (
      <span class="ml-1 text-red-500" aria-label="required">*</span>
    )}
  </p>

  <!-- question input -->
  {question.type === 'multiple_choice' && (
    <MultipleChoice name={inputName} options={question.options} value={scalarValue} />
  )}
  {question.type === 'select_all' && (
    <SelectAll name={inputName} options={question.options} values={arrayValue} />
  )}
  {question.type === 'dropdown' && (
    <Dropdown name={inputName} options={question.options} value={scalarValue} />
  )}
  {question.type === 'free_text' && (
    <FreeText name={inputName} value={scalarValue} />
  )}

  <!-- error slot -->
  {error && (
    <p class="mt-3 text-sm text-red-600" role="alert">{error}</p>
  )}
</div>
