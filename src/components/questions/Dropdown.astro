---
import type { Option } from '../../lib/database.types';

interface Props {
  name: string;
  options: Option[];
  value?: string;
  placeholder?: string;
  labelId?: string;
  required?: boolean;
  inputFocusClass?: string;
}

const { name, options, value, placeholder = 'Select an option…', labelId, required = false, inputFocusClass = 'focus:border-violet-500/60 focus:ring-violet-500/30' } = Astro.props;
---

<div class="relative">
  <select
    name={name}
    aria-labelledby={labelId}
    aria-required={required ? 'true' : undefined}
    class:list={["w-full appearance-none rounded-xl border border-white/15 bg-white/8 px-4 py-2.5 pr-10 text-sm text-white shadow-sm backdrop-blur-sm transition-colors focus:outline-none focus:ring-2", inputFocusClass]}
  >
    <option value="" disabled selected={!value} class="bg-gray-900 text-white/60">{placeholder}</option>
    {options.map((option) => (
      <option value={option.value} selected={value === option.value} class="bg-gray-900 text-white">
        {option.label}
      </option>
    ))}
  </select>
  <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center" aria-hidden="true">
    <svg class="h-4 w-4 text-white/40" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
    </svg>
  </div>
</div>
