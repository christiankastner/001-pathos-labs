---
interface Props {
  name: string;
  value?: string;
  placeholder?: string;
  rows?: number;
  labelId?: string;
  required?: boolean;
}

const { name, value, placeholder = 'Your answer…', rows = 4, labelId, required = false } = Astro.props;
---

<textarea
  name={name}
  rows={rows}
  placeholder={placeholder}
  aria-labelledby={labelId}
  aria-required={required ? 'true' : undefined}
  class="w-full resize-y rounded-xl border border-white/15 bg-white/8 px-4 py-2.5 text-sm text-white shadow-sm backdrop-blur-sm placeholder:text-white/30 transition-colors focus:border-violet-500/60 focus:outline-none focus:ring-2 focus:ring-violet-500/30"
>{value ?? ''}</textarea>
