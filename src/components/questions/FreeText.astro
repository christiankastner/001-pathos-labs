---
interface Props {
  name: string;
  value?: string;
  placeholder?: string;
  rows?: number;
}

const { name, value, placeholder = 'Your answer…', rows = 4 } = Astro.props;
---

<textarea
  name={name}
  rows={rows}
  placeholder={placeholder}
  class="w-full resize-y rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-700 shadow-sm placeholder:text-gray-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
>{value ?? ''}</textarea>
