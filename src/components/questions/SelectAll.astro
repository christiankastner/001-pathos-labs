---
import type { Option } from '../../lib/database.types';

interface Props {
  name: string;
  options: Option[];
  values?: string[];
  labelId?: string;
  required?: boolean;
}

const { name, options, values = [], labelId, required = false } = Astro.props;
---

<fieldset
  aria-labelledby={labelId}
  aria-required={required ? 'true' : undefined}
  class="flex flex-col gap-2 border-0 p-0 m-0"
>
  <p class="mb-1 text-xs text-white/40">Select all that apply.</p>
  {options.map((option) => {
    const optId = `${name}_${option.value}`;
    return (
      <label for={optId} class="flex items-center gap-3 cursor-pointer group">
        <input
          type="checkbox"
          id={optId}
          name={name}
          value={option.value}
          checked={values.includes(option.value)}
          class="w-4 h-4 accent-violet-500 shrink-0 cursor-pointer rounded"
        />
        <span class="text-sm text-white/70 transition-colors group-hover:text-white">
          {option.label}
        </span>
      </label>
    );
  })}
</fieldset>
